{
  "app": {
    // 签名配置留空，由开发者在 DevEco Studio 中自动生成或手动配置
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        // 未配置签名：signingConfigs 为空时不应引用 signingConfig，
        // 在 DevEco Studio 中生成签名后再补 "signingConfig": "default"
        "compatibleSdkVersion": "6.0.0(20)",
        "compileSdkVersion": "6.0.0(20)",
        "targetSdkVersion": "6.0.0(20)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./products/default/entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "chat",
      "srcPath": "./features/chat",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "agents",
      "srcPath": "./features/agents",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
