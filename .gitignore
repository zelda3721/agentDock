/node_modules
/oh_modules
**/node_modules
**/oh_modules

# ---------- 构建产物 ----------
/.hvigor
**/.hvigor
.cxx
**/.cxx
/build
**/build
/.clangd
/.clang-format
/.clang-tidy
/.appanalyzer
/.test

# ---------- 工具生成物 ----------
